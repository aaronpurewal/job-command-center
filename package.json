{
  "name": "job-command-center",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Job search tracker and auto-apply agent for FDE / AI Deployment roles",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "scrape": "tsx server/agents/scrape-agent.ts",
    "apply": "tsx server/agents/apply-agent.ts",
    "apply:batch": "tsx server/agents/apply-agent.ts --batch"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@anthropic-ai/sdk": "latest",
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.0.0"
  }
}
